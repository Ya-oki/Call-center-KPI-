# ─────────────────────────────────────────────────────────────────────────────
# Retention Engine — environment configuration
# Copy to .env.local for local dev. NEVER commit real secrets (see .gitignore).
# All runtime config is env-driven so the app is portable off Supabase/Vercel.
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase (current hosting) ---
# Public, safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only, least-privilege service role (used by server actions / route handlers).
# Never expose to the client. Rotate on leak.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth adapter selection (portability seam, see lib/auth) ---
# 'supabase' now; swap to the company IdP adapter later without touching the engine.
AUTH_PROVIDER=supabase

# --- Storage adapter selection (portability seam, see lib/storage) ---
STORAGE_PROVIDER=supabase

# --- Direct Postgres connection (for migrations / portability to own infra) ---
# When running schema.sql against any standard Postgres:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/retention_engine
